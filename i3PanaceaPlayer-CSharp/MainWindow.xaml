<Window x:Class="i3PanaceaPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="i3 Panacea Player" Height="700" Width="1000"
        Background="#1a1a2e">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Login Panel -->
        <StackPanel x:Name="LoginPanel" Grid.Row="0" Grid.RowSpan="2"
            VerticalAlignment="Center" HorizontalAlignment="Center"
            Width="300">
            <TextBlock Text="i3 Panacea Player" FontSize="24" 
               Foreground="White" HorizontalAlignment="Center" 
               Margin="0,0,0,30"/>
            <TextBlock Text="Room Number" Foreground="White" Margin="0,0,0,5"/>
            <TextBox x:Name="RoomNumberBox"
             Margin="0,0,0,10" FontSize="14"/>
            <TextBlock Text="PIN" Foreground="White" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PinBox"
                 Margin="0,0,0,20" FontSize="14"/>
            <Button x:Name="LoginButton" Content="Login" 
            Click="LoginButton_Click"
            FontSize="14" Background="#e94560" Foreground="White"/>
            <TextBlock x:Name="ErrorText" Foreground="Red" 
               HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Content Panel -->
        <StackPanel x:Name="ContentPanel" Grid.Row="0" Visibility="Collapsed"
                    Background="#16213e" Margin="10">
            <TextBlock x:Name="WelcomeText" Foreground="White" 
                       FontSize="16" Margin="0,0,0,5"/>
            <Button Content="Logout" HorizontalAlignment="Right"
                    Click="LogoutButton_Click" Padding="5,2"
                    Background="#e94560" Foreground="White"/>
        </StackPanel>

        <Grid x:Name="MainPanel" Grid.Row="1" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Content List -->
            <DockPanel Grid.Column="0" Background="#16213e">
                <TextBlock DockPanel.Dock="Top" Text="Content" 
                           Foreground="White" FontSize="18" 
                           Padding="10" Background="#0f3460"/>
                <ListBox x:Name="ContentList" Background="#16213e"
                         Foreground="White" SelectionChanged="ContentList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding Title}" 
                                           FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding CategoryName}" 
                                           Foreground="#aaaaaa" FontSize="12"/>
                                <TextBlock Text="{Binding Year}" 
                                           Foreground="#aaaaaa" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Video Player -->
            <Grid Grid.Column="1" Background="Black">
                <MediaElement x:Name="VideoPlayer" 
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop"
                              Stretch="Uniform"/>
                <TextBlock x:Name="PlayerStatus" Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontSize="16"
                           Text="Select a video to play"/>
            </Grid>
        </Grid>
    </Grid>
</Window>